      "darkImage": "assets/images/quickstart/dark/sunstone_login_page.png",
      "environment": "existing-sunstone",
      "recipe": "recipes/quickstart-minione.json",
      "capture": "login-page",
      "theme": "both",
      "tags": ["quickstart", "quickstart-sequence", "sunstone", "login"],
      "status": "draft",
      "notes": "First capture in the sequence. The next capture continues from this page state."
    },
