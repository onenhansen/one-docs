{
  "$schema": "./schemas/manifest.schema.json",
  "version": 1,
  "defaults": {
    "viewport": {
      "width": 1440,
      "height": 1000,
      "deviceScaleFactor": 1
    },
    "locale": "en-US",
    "theme": "light",
    "sunstone": {
      "url": "${SUNSTONE_URL}",
      "username": "${SUNSTONE_USER}",
      "password": "${SUNSTONE_PASSWORD}"
    }
  },
  "environments": {
    "existing-sunstone": {
      "kind": "existing-sunstone",
      "notes": "Use SUNSTONE_URL, SUNSTONE_USER, and SUNSTONE_PASSWORD from the local shell."
    }
  },
  "screenshots": [
